# Qt Creator / qmake user files
*.user
*.por.user*
*qbs.user*
*.qmlproject.user*

# Build directories (Qt Creator suele crear build-*)
build*/
**/build*/
build-*/

# qmake build outputs (a veces aparecen si compilas dentro del proyecto
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
*.qm
*.qrc.depends
*.qrc.resources

# Binaries / objects
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dill
*.exe

# Common OS cruft
.DS_Store
Thumbs.db

# C++ y Objetos - Qt Creator
# --------------------------

# Ignorar cualquier carpeta llamada build o que empiece con build en cualquier nivel
**/build/
**/build-*/

# Ignorar caché de Clangd y configuraciones de Qt Creator
**/.qtc_clangd/
**/.cache/
*.pro.user*

# Archivos de configuración de usuario de Qt Creator (específicos de tu PC)
*.pro.user
*.pro.user.*

# Archivos temporales de compilación
*.o
*.obj
*.moc
*.qrc.cpp
ui_*.h

# Ejecutables (Windows)
*.exe
*.dll

# Debug/Release folders
debug/
release/

# Archivos de VS Code (por si usas ese editor a veces)
.vscode/
.vs/
